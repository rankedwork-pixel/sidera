# =============================================================================
# Sidera — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to git.
#
# Required: ANTHROPIC_API_KEY, DATABASE_URL
# Optional: Everything else (app works with graceful degradation)
# =============================================================================

# =============================================================================
# REQUIRED SERVICES
# =============================================================================

# --- Anthropic (Claude API) ---
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (PostgreSQL + Auth) ---
# Get from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Get from https://supabase.com/dashboard → Project Settings → Database → Connection string
# Use the "URI" format and replace [YOUR-PASSWORD] with your DB password
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# OPTIONAL SERVICES — App runs without these (features degrade gracefully)
# =============================================================================

# --- Redis (Upstash) ---
# Get from https://console.upstash.com → Create Database → REST URL
REDIS_URL=rediss://default:password@your-instance.upstash.io:6379

# --- Google Ads API ---
# Developer token: https://ads.google.com/aw/apicenter (requires approved API access)
GOOGLE_ADS_DEVELOPER_TOKEN=your-dev-token
# OAuth client: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
# Generated via OAuth flow — leave blank, Sidera's OAuth route handles this
GOOGLE_ADS_REFRESH_TOKEN=
# Your MCC (manager) account ID without dashes: https://ads.google.com → top-right account number
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Meta (Facebook) Marketing API ---
# Create at https://developers.facebook.com/apps → Create App → Business type
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
# Generated via OAuth flow — leave blank, Sidera's OAuth route handles this
META_ACCESS_TOKEN=

# --- Google BigQuery (Backend Data) ---
# Project ID from https://console.cloud.google.com → Select project → copy ID
BIGQUERY_PROJECT_ID=your-project-id
# Dataset containing the advertiser's backend reporting tables
BIGQUERY_DATASET_ID=your_dataset
# Service account JSON (paste full JSON string, or leave blank for Application Default Credentials)
# Generate at https://console.cloud.google.com → IAM → Service Accounts → Create Key → JSON
BIGQUERY_CREDENTIALS_JSON=
# Override table names if your schema differs from defaults
BIGQUERY_TABLE_GOALS=goals
BIGQUERY_TABLE_ORDERS=orders
BIGQUERY_TABLE_CHANNEL_PERFORMANCE=channel_performance
BIGQUERY_TABLE_BUDGET_PACING=budget_pacing
BIGQUERY_TABLE_CAMPAIGN_ATTRIBUTION=campaign_attribution

# --- Google Drive / Docs / Sheets / Slides ---
# Reuses GOOGLE_ADS_CLIENT_ID and GOOGLE_ADS_CLIENT_SECRET from above.
# Generated via OAuth flow — leave blank, Sidera's OAuth route handles this
GOOGLE_DRIVE_REFRESH_TOKEN=

# --- Slack ---
# Create at https://api.slack.com/apps → Create New App → From Scratch
# Bot token: OAuth & Permissions → Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...
# Signing secret: Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=
# Channel ID: right-click channel in Slack → View channel details → copy ID at bottom
SLACK_CHANNEL_ID=

# --- Inngest ---
# Get from https://app.inngest.com → Manage → Signing Key / Event Key
# For local dev, leave blank and run `npx inngest-cli@latest dev`
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry (Error Monitoring) ---
# Get from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=

# --- Token Encryption ---
# Fernet key for encrypting OAuth tokens at rest. Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Leave blank for development (tokens stored in plaintext).
TOKEN_ENCRYPTION_KEY=

# --- Recall.ai (Meeting Bot) ---
# Get from https://www.recall.ai/ → Dashboard → API Keys
# Required for listen-only meeting participation (transcript capture)
RECALL_AI_API_KEY=

# =============================================================================
# APP SETTINGS
# =============================================================================

# --- API Authentication ---
# Required in production. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# In development, leave blank to skip auth on REST endpoints.
API_KEY=

# --- RBAC ---
# Default role for unknown Slack users (not in the users table).
# Options: admin, approver, viewer, none (none = blocked entirely)
RBAC_DEFAULT_ROLE=approver
# Default clearance for unknown Slack users (not in the users table).
# Options: public, internal, confidential, restricted
RBAC_DEFAULT_CLEARANCE=public
# Slack user ID of the CEO — auto-seeded with admin + restricted clearance
CEO_USER_ID=

# --- App Settings ---
# Options: development, staging, production
APP_ENV=development
# Options: DEBUG, INFO, WARNING, ERROR
APP_LOG_LEVEL=INFO
# Base URL for OAuth callbacks and API endpoints
APP_BASE_URL=http://localhost:8000

# --- Agent Timezone ---
# IANA timezone for agent time awareness (e.g., America/New_York, Europe/London, UTC)
# Agents will see the current date/time in their system prompt
AGENT_TIMEZONE=America/New_York

# --- Model Routing ---
# Override which Claude models to use for each tier. Defaults shown below.
# MODEL_FAST=claude-3-haiku-20240307
# MODEL_STANDARD=claude-sonnet-4-20250514
# MODEL_REASONING=claude-opus-4-20250514

# --- Cost Controls ---
# Maximum Claude API cost per ad account per day (in USD)
MAX_LLM_COST_PER_ACCOUNT_PER_DAY=10.00
# Maximum tool calls the agent can make in a single analysis cycle
MAX_TOOL_CALLS_PER_CYCLE=20
# Slack alert fires when daily cost exceeds this threshold (in USD)
COST_ALERT_THRESHOLD=5.00
# Maximum budget increase per write operation (1.5 = 50% cap)
# MAX_BUDGET_CHANGE_RATIO=1.5

# --- Auto-Execute (Graduated Trust) ---
# Global kill switch — default OFF. Set to true to enable rule-based auto-execution.
# AUTO_EXECUTE_ENABLED=false
# Maximum auto-executed actions per day across all rules
# AUTO_EXECUTE_MAX_PER_DAY=20
# Slack channel for auto-execute notifications (defaults to SLACK_CHANNEL_ID)
# AUTO_EXECUTE_NOTIFY_CHANNEL=

# --- Conversation Mode ---
# Maximum turns per Slack thread conversation (default: 20)
# CONVERSATION_MAX_TURNS_PER_THREAD=20
# Thread timeout in hours (default: 24)
# CONVERSATION_THREAD_TIMEOUT_HOURS=24
# Maximum Claude API cost per thread (default: $5)
# CONVERSATION_MAX_COST_PER_THREAD=5.00
# Tool calls allowed per conversation turn (default: 10)
# CONVERSATION_TOOL_CALLS_PER_TURN=10

# --- Meeting Settings ---
# Maximum meeting duration in minutes (default: 120)
MEETING_MAX_DURATION_MINUTES=120
# Maximum Claude API cost per meeting session (default: $10)
MEETING_MAX_COST_PER_SESSION=10.00
# Override model for meeting agent (defaults to MODEL_STANDARD / Sonnet)
# MEETING_AGENT_MODEL=
# Allow agent to speak proactively without being addressed (default: true)
MEETING_SPEAK_PROACTIVELY=true
# Process transcript every N seconds (default: 30)
MEETING_TRANSCRIPT_CHUNK_SECONDS=30

# --- Data Retention (days, 0 = keep forever) ---
# RETENTION_AUDIT_LOG_DAYS=365
# RETENTION_ANALYSIS_RESULTS_DAYS=180
# RETENTION_COST_TRACKING_DAYS=180
# RETENTION_DECIDED_APPROVALS_DAYS=90
# RETENTION_RESOLVED_FAILED_RUNS_DAYS=30
# RETENTION_INACTIVE_THREADS_DAYS=30
# RETENTION_COLD_MEMORIES_DAYS=0
# RETENTION_DAILY_METRICS_DAYS=365

# --- Hybrid LLM Routing ---
# Route high-volume structured tasks (routing, memory extraction, reflection)
# to cheaper OpenAI-compatible providers. Quality-critical tasks stay on Claude.
# EXTERNAL_LLM_ENABLED=false
# Provider identifier (for logging/metrics)
# EXTERNAL_LLM_PROVIDER=groq
# OpenAI-compatible base URL
# EXTERNAL_LLM_ENDPOINT=https://api.groq.com/openai/v1
# EXTERNAL_LLM_API_KEY=gsk_...
# Model ID at the external provider
# EXTERNAL_LLM_MODEL=llama-3.1-70b-versatile
# HTTP timeout in seconds
# EXTERNAL_LLM_TIMEOUT=30.0
# Task types to route externally (comma-separated in env, list in config)
# EXTERNAL_LLM_TASKS=["skill_routing","role_routing","memory_extraction","reflection","memory_consolidation","memory_versioning","friction_detection","phase_compression"]

# --- Token Encryption (rotation) ---
# Previous encryption key, kept for decrypt-only during key rotation
# TOKEN_ENCRYPTION_KEY_PREVIOUS=
